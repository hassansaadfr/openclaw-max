# Subscription auth (Claude Pro/Max). Generate on your host with:
#   claude setup-token
# Then copy this file to `.env` and paste the token below.
CLAUDE_CODE_OAUTH_TOKEN=

# Gateway access token — only needed when running the OpenClaw gateway / Control UI
# (the Coolify deployment). Use a long random value, e.g.  openssl rand -hex 32
OPENCLAW_GATEWAY_TOKEN=

# Public origin(s) of the Control UI behind a reverse proxy (Coolify/Traefik).
# Comma-separated, scheme + host, no trailing slash. Required or the gateway
# rejects the browser with "Browser origin not allowed".
# e.g. OPENCLAW_ALLOWED_ORIGINS=https://openclaw.example.com
OPENCLAW_ALLOWED_ORIGINS=
