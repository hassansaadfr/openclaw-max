# Subscription auth (Claude Pro/Max). Generate on your host with:
#   claude setup-token
# Then copy this file to `.env` and paste the token below.
CLAUDE_CODE_OAUTH_TOKEN=

# Gateway access token — only needed when running the OpenClaw gateway / Control UI
# (the Coolify deployment). Use a long random value, e.g.  openssl rand -hex 32
OPENCLAW_GATEWAY_TOKEN=
